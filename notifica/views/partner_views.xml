<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── mail.message with is_external_log (read-only) ───────── -->
    <record id="view_mail_message_tree_external" model="ir.ui.view">
        <field name="name">mail.message.tree.external</field>
        <field name="model">mail.message</field>
        <field name="arch" type="xml">
            <tree string="External Logs" create="false" edit="false" delete="false">
                <field name="date" string="Log Date"/>
                <field name="subject"/>
            </tree>
        </field>
    </record>

    <record id="action_window_external_logs" model="ir.actions.act_window">
        <field name="name">External Logs</field>
        <field name="res_model">mail.message</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('is_external_log', '=', True)]</field>
        <field name="view_id" ref="view_mail_message_tree_external"/>
    </record>

    <!-- ── Smart button: open full comm.log list ──────────────────────── -->
    <record id="action_comm_log_partner" model="ir.actions.act_window">
        <field name="name">Communications</field>
        <field name="res_model">comm.log</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('partner_id', '=', active_id)]</field>
        <field name="context">{'search_default_partner_id': active_id}</field>
    </record>

    <record id="view_partner_form_inherit_comm_log" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.comm.log</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Smart button in the button box -->
            <div name="button_box" position="inside">
                <button name="%(action_comm_log_partner)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-history"
                        context="{'search_default_partner_id': active_id}">
                    <div class="o_stat_info">
                        <field name="comm_log_count" widget="statinfo" nolabel="1"/>
                        <span class="o_stat_text">Communications</span>
                    </div>
                </button>
            </div>

            <!-- Preview tab in the notebook -->
            <xpath expr="//notebook/page[last()]" position="after">
                <page string="Communications" name="comm_log">
                    <field name="comm_log_ids" nolabel="1">
                        <tree default_order="date desc" limit="20">
                            <field name="date"/>
                            <field name="subject"/>
                            <field name="source_type" widget="badge"/>
                            <field name="origin_app" widget="badge"/>
                            <field name="status" widget="badge"/>
                            <field name="recipient_email"/>
                        </tree>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
