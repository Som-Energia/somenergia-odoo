<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_pbx_extension" model="ir.ui.view">
        <field name="name">res.users.form.pbx_extension</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='messaging']" position="after">
                <group string="PBX / CTI">
                    <field name="pbx_extension"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
