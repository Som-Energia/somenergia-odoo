<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_import_openproject_timesheets" model="ir.cron">
            <field name="name">OpenProject - Import weekly timesheets</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field
                name="nextcall"
                eval="(DateTime.now() + timedelta(days=((6 - DateTime.now().weekday()) % 7) or 7)).strftime('%Y-%m-%d 08:00:00')"
            />
            <field name="doall" eval="False"/>
            <field name="active" eval="False"/>
            <field name="model_id" ref="analytic.model_account_analytic_line"/>
            <field name="state">code</field>
            <field name="code">model._cron_import_openproject_timesheets()</field>
        </record>
    </data>
</odoo>
